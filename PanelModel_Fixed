extended_forecast_rows = []
arima_param_frames = []

for tech in technologies_iter:
    tech_data = (
        all_technology_data[all_technology_data["Technology"] == tech]
        .sort_values("Year")
        .copy()
    )

    train_data = tech_data[tech_data["Year"] <= cutoff_training].copy()

    test_data = tech_data[
        (tech_data["Year"] > cutoff_training)
        & (tech_data["Year"] <= forecast_end_year)
    ].copy()

    if train_data.empty or test_data.empty:
        print(f"Skipping forecast comparison for {tech}: insufficient data.")
        continue

    if tech not in entity_effects_train_df.index:
        print(f"Skipping forecast comparison for {tech}: no training fixed effect.")
        continue

    y_train = train_data["Technology_Growth"].values
    y_test = test_data["Technology_Growth"].values

    future_years = test_data["Year"].values
    forecast_steps = len(future_years)

    future_years_extended = np.arange(
        forecast_end_year + 1,
        extended_forecast_end_year + 1,
    )

    extended_forecast_steps = len(future_years_extended)

    # -------------------------------------------------------------------------
    # Panel FE forecast for the test period
    # -------------------------------------------------------------------------

    entity_effect_train_tech = entity_effects_train_df.loc[tech, "estimated_effects"]

    panel_forecast_test = (
        entity_effect_train_tech
        + const_train
        + beta_train * test_data["Weighted_Cited_Classes_Growth"].values
    )

    rmse_panel = np.sqrt(mean_squared_error(y_test, panel_forecast_test))

    # -------------------------------------------------------------------------
    # Panel in-sample diagnostic plot
    # -------------------------------------------------------------------------

    try:
        panel_fitted_train = (
            results_panel_train
            .fitted_values
            .loc[tech]["fitted_values"]
            .values
        )

        panel_fit_plot_df = pd.concat(
            [
                pd.DataFrame({
                    "Year": train_data["Year"].values,
                    "Value": train_data["Technology_Growth"].values,
                    "Series": "Actual",
                }),
                pd.DataFrame({
                    "Year": train_data["Year"].values,
                    "Value": panel_fitted_train,
                    "Series": "Panel FE fitted",
                }),
            ],
            ignore_index=True,
        )

        save_long_lineplot(
            plot_df=panel_fit_plot_df,
            output_file=(
                f"plots/forecast/panel_insample_fit/"
                f"PanelInSampleFit_{tech}_{cutoff_training}.png"
            ),
            title=f"{tech}: Panel FE In-Sample Fit",
            ylabel="Technology growth",
        )

    except Exception as error:
        print(f"Could not create panel fitted-value plot for {tech}: {error}")

    # -------------------------------------------------------------------------
    # ARIMA benchmark for test period
    # -------------------------------------------------------------------------

    forecast_ARIMA_test, model_fit_test = safe_arima_forecast(
        y_train,
        forecast_steps,
    )

    if model_fit_test is not None:
        try:
            params = model_fit_test.params()
            stderr = model_fit_test.bse()
            pvalues = model_fit_test.pvalues()
            order = model_fit_test.order
            param_names = model_fit_test.arima_res_.param_names

            arima_param_frames.append(pd.DataFrame({
                "Parameter": param_names,
                "Estimate": params,
                "Std Error": stderr,
                "p-value": pvalues,
                "Technology": tech,
                "ARIMA Order": [order] * len(params),
            }))

            fitted_values = model_fit_test.predict_in_sample()

            arima_fit_plot_df = pd.concat(
                [
                    pd.DataFrame({
                        "Year": train_data["Year"].values,
                        "Value": y_train,
                        "Series": "Actual",
                    }),
                    pd.DataFrame({
                        "Year": train_data["Year"].values,
                        "Value": fitted_values,
                        "Series": "ARIMA fitted",
                    }),
                ],
                ignore_index=True,
            )

            save_long_lineplot(
                plot_df=arima_fit_plot_df,
                output_file=(
                    f"plots/forecast/arima_fit/"
                    f"ARIMA_{tech}_{cutoff_training}_comparison.png"
                ),
                title=f"{tech}: ARIMA In-Sample Fit",
                ylabel="Technology growth",
            )

        except Exception as error:
            print(f"Could not save ARIMA diagnostics for {tech}: {error}")

    rmse_arima = np.sqrt(mean_squared_error(y_test, forecast_ARIMA_test))

    # -------------------------------------------------------------------------
    # Random walk benchmark for test period
    # -------------------------------------------------------------------------

    forecast_RW_test = random_walk_forecast(y_train, forecast_steps)
    rmse_rw = np.sqrt(mean_squared_error(y_test, forecast_RW_test))

    candidates = {
        "Panel FE": rmse_panel,
        "ARIMA": rmse_arima,
        "Random Walk": rmse_rw,
    }

    best_model = min(candidates, key=candidates.get)

    rmse_rows.append({
        "Technology": tech,
        "RMSE_Panel": rmse_panel,
        "RMSE_ARIMA": rmse_arima,
        "RMSE_RandomWalk": rmse_rw,
        "Best_Model": best_model,
    })

