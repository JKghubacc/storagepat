        ]["Relativegrowth"].sum()

        anng_forecasted_extended.append(temp_anng)

    anng_forecasted_extended = np.array(anng_forecasted_extended, dtype=float)

    if tech not in entity_effects_full_df.index:
        print(f"Skipping extended panel forecast for {tech}: no full-sample fixed effect.")
        continue

    entity_effect_full_tech = entity_effects_full_df.loc[tech, "estimated_effects"]

    panel_forecast_extended = (
