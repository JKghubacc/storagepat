        output_file=(
            f"plots/forecast/comparison_panel/"
            f"ForecastComparison_Panel_ARIMA_RW_{tech}_{cutoff_training}.png"
        ),
        title=f"{tech}: Forecast Comparison",
        ylabel="Technology growth",
        vertical_lines=[(cutoff_training, "--")],
