def clean_numeric(series):
    """Convert a Series to numeric values and replace infinite values with NaN."""
    return pd.to_numeric(series, errors="coerce").replace([np.inf, -np.inf], np.nan)


def calculate_growth(series, periods=1, use_logs=False):
    """Calculate percentage or log growth."""
    pct_change = series.pct_change(periods=periods)

    if use_logs:
        return np.log1p(pct_change)

    return pct_change


def safe_compound_growth(growth_values):
    """Calculate cumulative growth from a sequence of growth rates."""
    growth_values = np.asarray(growth_values, dtype=float)
    growth_values = growth_values[np.isfinite(growth_values)]

    if len(growth_values) == 0:
        return np.nan

    return np.prod(1 + growth_values) - 1


def create_citation_vector(aggregated_citations):
    """Create a sorted citation vector indexed by CPC class."""
    if aggregated_citations.empty:
        return pd.Series(dtype=float, name="total_normalized_citations")

    citation_vector = (
        aggregated_citations
        .set_index("cpc_class")["total_normalized_citations"]
        .sort_index()
    )

    citation_vector.name = "total_normalized_citations"

    return citation_vector


def normalize_citation_vector(citation_vector):
    """Normalize a citation vector so that all weights sum to one."""
    if citation_vector.empty:
        return pd.Series(dtype=float, name="total_normalized_citations")

    total_sum = citation_vector.sum()

    if total_sum <= 0 or not np.isfinite(total_sum):
        return pd.Series(dtype=float, name="total_normalized_citations")

    normalized_vector = citation_vector / total_sum
    normalized_vector.name = "total_normalized_citations"

    return normalized_vector


def safe_arima_forecast(y_train, n_periods):
    """
    Estimate an ARIMA model and forecast n periods ahead.
    If the time series is too short or estimation fails, fall back to a random walk.
    """
    y_train = np.asarray(y_train, dtype=float)
    y_train = y_train[np.isfinite(y_train)]

    if len(y_train) == 0:
        return np.repeat(np.nan, n_periods), None

    if len(y_train) < 5:
        return np.repeat(y_train[-1], n_periods), None

    try:
        model_fit = auto_arima(
            y_train,
            start_p=0,
            start_q=0,
            max_p=3,
            max_q=3,
            seasonal=False,
            suppress_warnings=True,
            error_action="ignore",
            stepwise=True,
        )

        forecast = np.asarray(model_fit.predict(n_periods=n_periods), dtype=float)

        return forecast, model_fit

    except Exception as error:
        print(f"ARIMA estimation failed, using random walk instead. Error: {error}")
        return np.repeat(y_train[-1], n_periods), None


def random_walk_forecast(y_train, n_periods):
    """Forecast future values using the last observed value."""
    y_train = np.asarray(y_train, dtype=float)
    y_train = y_train[np.isfinite(y_train)]

    if len(y_train) == 0:
        return np.repeat(np.nan, n_periods)

    return np.repeat(y_train[-1], n_periods)


