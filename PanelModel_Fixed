def prepare_cpc_growth_data(file_path):
    """
    Prepare a balanced CPC class-year panel with cumulative counts and growth rates.
    """
    df = pd.read_csv(file_path)

    df = df[df["Year"] != 9999].copy()
    df["Year"] = clean_numeric(df["Year"])
    df["Normalized_Count"] = clean_numeric(df["Normalized_Count"])
    df = df.dropna(subset=["Class", "Year", "Normalized_Count"])
    df["Year"] = df["Year"].astype(int)

    df = df.sort_values(by=["Class", "Year"])

    min_year = int(df["Year"].min())
    max_year = int(df["Year"].max())

    yearframe = pd.DataFrame({"Year": range(min_year, max_year + 1)})

    filled_frames = []

    for cls in df["Class"].unique():
        class_df = df[df["Class"] == cls].copy()
        class_df = pd.merge(yearframe, class_df, on="Year", how="left")
        class_df["Class"] = cls
        class_df["Normalized_Count"] = class_df["Normalized_Count"].fillna(0)
        class_df["Cumulative_Sum"] = class_df["Normalized_Count"].cumsum()
        filled_frames.append(class_df)

    filled_df = pd.concat(filled_frames, ignore_index=True)
    filled_df = filled_df.sort_values(by=["Class", "Year"])

    growth_col = f"Growth_Rate_{x}_Years"

    filled_df[growth_col] = (
        filled_df
        .groupby("Class")["Cumulative_Sum"]
        .transform(lambda s: calculate_growth(s, periods=x, use_logs=(logs == 1)))
    )

    total_cumulative_sum = (
        filled_df
        .groupby("Year")["Cumulative_Sum"]
        .sum()
        .reset_index()
        .rename(columns={"Cumulative_Sum": "Total_Cumulative_Sum"})
    )

    total_growth_col = f"Total_Growth_Rate_{x}_Years"

    total_cumulative_sum[total_growth_col] = calculate_growth(
        total_cumulative_sum["Total_Cumulative_Sum"],
        periods=x,
        use_logs=(logs == 1),
    )

    filled_df = filled_df.merge(
        total_cumulative_sum[["Year", "Total_Cumulative_Sum", total_growth_col]],
        on="Year",
        how="left",
    )

    filled_df[growth_col] = clean_numeric(filled_df[growth_col])
    filled_df[total_growth_col] = clean_numeric(filled_df[total_growth_col])

    filled_df[f"Normalized_Growth_Rate_{x}_Years"] = (
        filled_df[growth_col] / filled_df[total_growth_col]
    )

    filled_df = filled_df.replace([np.inf, -np.inf], np.nan)

    # The panel construction only requires class-level growth.
    filled_df = filled_df.dropna(subset=[growth_col])

    return filled_df


