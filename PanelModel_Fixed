            pd.DataFrame({
                "Year": future_years_extended,
                "Value": forecast_ARIMA_extended,
                "Series": "ARIMA forecast",
            }),
            pd.DataFrame({
                "Year": future_years_extended,
                "Value": forecast_RW_extended,
                "Series": "Random walk forecast",
            }),
        ],
        ignore_index=True,
