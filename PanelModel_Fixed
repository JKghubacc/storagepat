    # Extended forecasts, 2024–2030
    # -------------------------------------------------------------------------

    citationvector_unconditional = margincitframe[
        margincitframe["Technology"] == tech
    ].copy()

    unconditional_anng = pd.merge(
        citationvector_unconditional,
        forecasted_df,
