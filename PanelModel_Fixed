        .reset_index()
        .sort_values("RMSE")
    )

    plt.figure(figsize=(8, 5))

    sns.barplot(
        data=avg_rmse,
        x="Model",
        y="RMSE",
    )

    plt.title("Average Forecast Accuracy Across Technologies")
    plt.xlabel("")
    plt.ylabel("Average RMSE")
    plt.tight_layout()
    plt.savefig(
        "plots/analysis/average_rmse_panel_arima_randomwalk.png",
        dpi=300,
        bbox_inches="tight",
    )
    plt.close()


